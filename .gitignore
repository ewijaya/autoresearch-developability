# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Data (raw downloads tracked via manifests, not git)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Results (generated, not checked in except selected baselines and loop logs)
results/loops/*
results/ablations/*
results/figures/*
!results/loops/*.tsv
!results/loops/.gitkeep
!results/ablations/.gitkeep
!results/figures/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# uv
uv.lock
