# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Data (raw downloads tracked via manifests, not git)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Results (generated, not checked in except loop results and summaries)
results/loops/*/workspace/
results/loops/*/logs/
results/loops/*/diffs/
results/loops/*/rank_versions/
results/loops/*/.state/
results/loops/*/agent_session.log
results/loops/*/last_message.txt
results/loops/*/prompt.txt
results/ablations/*
results/figures/*
results/run_all.log
!results/loops/**/results.tsv
!results/loops/**/summary.json
!results/loops/.gitkeep
!results/ablations/.gitkeep
!results/figures/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# uv
uv.lock
